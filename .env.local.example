# Scaleway Generative APIs — OpenAI-compatible LLM endpoint.
# In production these are minted + injected by Terraform. For local dev
# you can point LLM_BASE_URL at https://api.scaleway.ai/v1 and paste a
# Scaleway IAM API key with GenerativeApisFullAccess into LLM_API_KEY.
LLM_API_KEY=
LLM_BASE_URL=https://api.scaleway.ai/v1
LLM_TEXT_MODEL=llama-3.1-70b-instruct
LLM_VISION_MODEL=pixtral-12b-2409

# Embedding model for SRD RAG retrieval (Scaleway Generative APIs)
LLM_EMBEDDING_MODEL=bge-multilingual-gemma2

# Optional: Scaleway Managed Redis for session persistence. If unset the
# app automatically falls back to the in-memory session store.
# Example: rediss://default:<password>@<host>:<port>
REDIS_URL=

# Scaleway Object Storage (for character-sheet presigned uploads)
SCW_OBJECT_STORAGE_ACCESS_KEY=
SCW_OBJECT_STORAGE_SECRET_KEY=
SCW_CHARACTER_SHEETS_BUCKET=

# LangGraph feature flag — set to "true" to use LangGraph pipeline (default: imperative)
USE_LANGGRAPH=
